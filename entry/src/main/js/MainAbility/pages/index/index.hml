<div class="container">
    <text class="title">模式: {{mode}}</text>
    <text class="val">期望: {{expectedInterval}}ms</text>
    <text class="val">实际平均: {{actualInterval}}ms</text>
    <text class="val">最小: {{minInterval}}ms</text>
    <text class="val">最大: {{maxInterval}}ms</text>
    <text class="val">总次数: {{callbackCount}}</text>
</div>
